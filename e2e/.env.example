# Phase 6.12d route-smoke configuration.
# Copy this file to `e2e/.env` (gitignored) and fill in the values, OR export
# the same variables in your shell. Shell env vars take precedence.
#
# The full stack must be running before `npm run e2e`:
#   API (NestJS) + MongoDB + Redis + the served frontend (`npm start`).

# Served frontend origin (Angular dev server default).
E2E_BASE_URL=http://localhost:4200

# Admin account used to exercise /admin/* and /users/* routes.
# Leave blank to run ONLY the public-route checks (authenticated routes skip).
E2E_ADMIN_EMAIL=
E2E_ADMIN_PASSWORD=
