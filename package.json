{
    "name": "daplex-v2",
    "version": "0.0.0",
    "scripts": {
        "ng": "ng",
        "start": "ng serve",
        "build": "ng build",
        "postbuild": "node postbuild.js",
        "watch": "ng build --watch --configuration development",
        "check:console": "node check-console.js",
        "check:flex-gap": "node check-flex-gap.js",
        "lint:css": "stylelint \"src/**/*.{css,scss}\"",
        "pretest": "node check-console.js",
        "test": "ng test",
        "e2e": "playwright test",
        "e2e:report": "playwright show-report",
        "i18n:extract": "transloco-keys-manager extract -u",
        "i18n:find": "transloco-keys-manager find"
    },
    "private": true,
    "dependencies": {
        "@angular/animations": "21.2.15",
        "@angular/cdk": "21.2.13",
        "@angular/common": "21.2.15",
        "@angular/compiler": "21.2.15",
        "@angular/core": "21.2.15",
        "@angular/forms": "21.2.15",
        "@angular/platform-browser": "21.2.15",
        "@angular/platform-browser-dynamic": "21.2.15",
        "@angular/router": "21.2.15",
        "@angular/service-worker": "21.2.15",
        "@jsverse/transloco": "8.3.0",
        "@jsverse/transloco-messageformat": "8.3.0",
        "@jsverse/transloco-persist-translations": "8.3.0",
        "@ktt45678/ngx-image-cropper": "6.2.2",
        "@ngneat/cashew": "5.3.0",
        "@ngneat/tailwind": "7.0.3",
        "@ngrx/signals": "21.1.0",
        "@primeuix/motion": "^0.0.10",
        "@primeuix/styled": "^0.7.4",
        "@primeuix/styles": "^2.0.3",
        "@primeuix/themes": "npm:@yacucdeptrai/primeuix-themes@2.0.3-F2",
        "@primeuix/utils": "^0.7.2",
        "dashjs": "5.0.0",
        "date-fns": "4.1.0",
        "dompurify": "3.0.11",
        "fflate": "0.8.2",
        "jassub": "1.7.17",
        "jwt-decode": "4.0.0",
        "lodash-es": "4.17.21",
        "marked": "11.2.0",
        "material-symbols": "0.24.0",
        "media-captions": "npm:@ktt45678/media-captions@1.0.4-F1",
        "ng-lazyload-image": "9.1.3",
        "ng-recaptcha": "13.2.1",
        "ngx-infinite-scroll": "21.0.0",
        "primeicons": "^7.0.0",
        "primeng": "npm:@yacucdeptrai/primeng@21.1.9-F2",
        "rxjs": "7.8.1",
        "socket.io-client": "4.7.5",
        "swiper": "12.2.0",
        "tslib": "2.6.2",
        "vidstack": "npm:@ktt45678/vidstack@1.11.30-F5",
        "zone.js": "0.15.1"
    },
    "devDependencies": {
        "@angular/build": "21.2.13",
        "@angular/cli": "21.2.13",
        "@angular/compiler-cli": "21.2.15",
        "@jsverse/transloco-keys-manager": "8.1.0",
        "@playwright/test": "1.60.0",
        "@tailwindcss/aspect-ratio": "0.4.2",
        "@tailwindcss/line-clamp": "0.4.4",
        "@tailwindcss/typography": "0.5.12",
        "@types/dompurify": "3.0.5",
        "@types/jasmine": "3.10.18",
        "@types/lodash-es": "4.17.12",
        "@types/marked": "4.3.2",
        "@types/node": "20.12.5",
        "axe-core": "4.12.1",
        "jasmine-core": "3.99.1",
        "karma": "6.4.3",
        "karma-chrome-launcher": "3.2.0",
        "karma-coverage": "2.2.1",
        "karma-jasmine": "4.0.2",
        "karma-jasmine-html-reporter": "1.7.0",
        "postcss": "8.4.31",
        "postcss-scss": "4.0.9",
        "purgecss": "5.0.0",
        "stylelint": "16.25.0",
        "stylelint-no-unsupported-browser-features": "8.0.4",
        "tailwindcss": "3.4.3",
        "typescript": "5.9.3"
    },
    "overrides": {
        "ng-recaptcha": {
            "@angular/core": "$@angular/core",
            "@angular/common": "$@angular/common"
        },
        "media-captions": "npm:@ktt45678/media-captions@1.0.4-F1",
        "primeng": {
            "@angular/core": "$@angular/core",
            "@angular/common": "$@angular/common",
            "@angular/animations": "$@angular/animations",
            "@angular/forms": "$@angular/forms",
            "@angular/cdk": "$@angular/cdk",
            "zone.js": "$zone.js"
        },
        "vidstack": {
            "@angular/core": "$@angular/core"
        },
        "@ktt45678/ngx-image-cropper": {
            "@angular/core": "$@angular/core"
        }
    }
